# Lever — environment configuration
#
# All variables are OPTIONAL. With none set, Lever runs on an in-memory store
# (perfect for the live demo). Set the Firebase trio to switch persistence to
# Firestore automatically — no code change required (see src/lib/storage.ts).

# Firebase service account (from the Firebase console → Project settings → Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines (Vercel-safe); Lever restores them.
FIREBASE_PRIVATE_KEY=

# Alternatively, point at an application-default credentials JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── Persistence selection (priority: Firebase > local file DB > in-memory) ──
# Local file DB: real persistence with zero cloud dependency. Set a writable path.
# LEVER_DB_PATH=.lever/datasets.json

# ── Encrypted credential vault (channel API keys) ──
# Master secret used to seal/open channel credentials (AES-256-GCM, scrypt-derived).
# Set this (>= 8 chars) to persist credentials to disk; without it the vault is
# in-memory only (per-process). Channel credentials themselves are added at runtime
# via POST /api/credentials (never committed) — see docs/05-pm-roadmap.md.
# LEVER_SECRET_KEY=
# Override where the encrypted vault file lives (default .lever/credentials.enc.json).
# LEVER_VAULT_PATH=
# Require this token (x-lever-admin header) to write/delete credentials over HTTP.
# LEVER_ADMIN_TOKEN=

# ── Google Sheets sync (Apps Script web app) — see apps-script/Code.gs ──
# LEVER_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# LEVER_SHEETS_TOKEN=shared-secret-matching-Apps-Script-SHEET_TOKEN

# ── Scheduled ingest (Vercel Cron → GET /api/cron/ingest, see vercel.json) ──
# Required token Vercel Cron sends as `Authorization: Bearer <value>`. Without
# it the endpoint is open in dev but FAILS CLOSED in production.
# LEVER_CRON_SECRET=
