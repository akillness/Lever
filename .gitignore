# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# jeo agent workdir (never commit; may contain session secrets)
.jeo/

# Lever encrypted credential vault + local file DB (never commit secrets/data)
.lever/
*.enc.json
# god-tibo-imagen debug request/response dumps (local only, not product)
.debug-codex-imagegen/
# jeo runtime agent scratch space (never commit; local session state only)
.pi/
